# Source code (already bundled into dist/extension.js by webpack)
src/**
node_modules/**

# Build configuration (not needed at runtime)
tsconfig.json
webpack.config.js
vitest.config*

# Test infrastructure
.vitest/**
coverage/**

# Documentation (not needed at runtime)
AGENTS.md
design-language.md
debug-ide-plugin-freeze.md
troubleshooting-ide-plugin-freeze.md

# Package lock & gitignore (not needed at runtime)
package-lock.json
.gitignore

# Source maps (save ~50% dist/ space)
dist/*.map
.trae/**
