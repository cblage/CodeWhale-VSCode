{
  "name": "brotherwhale-vscode",
  "displayName": "%displayName%",
  "description": "%description%",
  "version": "0.3.1",
  "publisher": "hengquworld",
  "repository": "https://github.com/HengQuWorld/CodeWhale-VSCode",
  "engines": {
    "vscode": "^1.85.0"
  },
  "icon": "media/icon.png",
  "categories": [
    "AI",
    "Chat"
  ],
  "keywords": [
    "codewhale",
    "deepseek",
    "ai",
    "coding",
    "agent",
    "chat",
    "llm",
    "copilot",
    "assistant"
  ],
  "homepage": "https://github.com/HengQuWorld/CodeWhale-VSCode#readme",
  "bugs": {
    "url": "https://github.com/HengQuWorld/CodeWhale-VSCode/issues"
  },
  "galleryBanner": {
    "color": "#4D6BFE",
    "theme": "dark"
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "brotherwhale",
          "title": "%viewsContainers.activitybar.title%",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "brotherwhale": [
        {
          "type": "webview",
          "id": "brotherwhale.chat",
          "name": "%views.chat.name%"
        }
      ]
    },
    "commands": [
      {
        "command": "brotherwhale.openChat",
        "title": "%commands.openChat.title%"
      },
      {
        "command": "brotherwhale.newThread",
        "title": "%commands.newThread.title%"
      },
      {
        "command": "brotherwhale.compactContext",
        "title": "%commands.compactContext.title%"
      },
      {
        "command": "brotherwhale.restartEngine",
        "title": "%commands.restartEngine.title%"
      }
    ],
    "configuration": {
      "title": "BrotherWhale",
      "properties": {
        "brotherwhale.enginePath": {
          "type": "string",
          "default": "codewhale",
          "description": "%config.enginePath.description%"
        },
        "brotherwhale.enginePort": {
          "type": "number",
          "default": 7878,
          "description": "%config.enginePort.description%"
        },
        "brotherwhale.defaultModel": {
          "type": "string",
          "default": "deepseek-v4-pro",
          "description": "%config.defaultModel.description%"
        },
        "brotherwhale.defaultMode": {
          "type": "string",
          "enum": [
            "agent",
            "plan",
            "yolo"
          ],
          "default": "agent",
          "description": "%config.defaultMode.description%"
        },
        "brotherwhale.reasoningEffort": {
          "type": "string",
          "enum": [
            "auto",
            "off",
            "low",
            "medium",
            "high",
            "max"
          ],
          "default": "auto",
          "description": "%config.reasoningEffort.description%"
        },
        "brotherwhale.autoStartEngine": {
          "type": "boolean",
          "default": true,
          "description": "%config.autoStartEngine.description%"
        },
        "brotherwhale.autoApprove": {
          "type": "boolean",
          "default": false,
          "description": "%config.autoApprove.description%"
        },
        "brotherwhale.showThreadList": {
          "type": "boolean",
          "default": false,
          "description": "%config.showThreadList.description%"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "webpack --mode development",
    "watch": "webpack --mode development --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "lint": "eslint src --ext ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "marked": "^18.0.4",
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^2.22.0",
    "ts-loader": "^9.5.0",
    "typescript": "^5.4.0",
    "vitest": "^4.1.7",
    "webpack": "^5.90.0",
    "webpack-cli": "^5.1.0"
  }
}
